          "type": "contains",
          "target": "page.on(\"response\""
        }
      ]
    },
    {
      "id": 3,
      "prompt": "写个脚本批量下载 5 个视频回放，地址在 video_urls.txt 里",
      "expected_output": "生成批量下载脚本，支持 yt-dlp 或 curl",
      "files": ["video_urls.txt"],
      "assertions": [
        {
          "description": "支持批量处理",
          "type": "contains",
